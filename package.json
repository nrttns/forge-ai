{
  "name": "forge-ai",
  "version": "1.0.0",
  "description": "Bounded TypeScript distribution and bootstrap surface for the MD-first Forge AI Target Project; not the AI-DOS architectural or normative system definition",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "tsx test/boot.test.ts",
    "test:install": "npm run build && node scripts/validate-local-install.mjs",
    "test:execution": "npm run build && node scripts/validate-local-execution.mjs",
    "test:offline": "npm run build && node scripts/validate-offline.mjs",
    "test:uninstall": "npm run build && node scripts/validate-uninstall.mjs",
    "test:rollback": "npm run build && node scripts/validate-rollback.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.22.5",
    "typescript": "^5.9.3"
  },
  "private": true,
  "keywords": [
    "ai-dos",
    "md-first",
    "target-project",
    "governed-ai",
    "cli-bootstrap"
  ],
  "author": "",
  "license": "Apache-2.0",
  "type": "commonjs",
  "bin": {
    "forge-ai": "dist/main.js"
  },
  "files": [
    "dist"
  ]
}